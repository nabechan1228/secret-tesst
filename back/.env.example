# Stellaris Backend Environment Variables

# CORS 許可オリジン（カンマ区切り）。本番デプロイ時にフロントエンド URL を追加
# 例: CORS_ORIGINS=https://stellaris.example.com,http://localhost:3000
# CORS_ORIGINS=

# API ドキュメント (/docs, /redoc) の公開。本番では false 推奨
# ENABLE_API_DOCS=true

# レート制限: 非アクセス IP エントリの保持時間（秒）
# RATE_LIMIT_IP_TTL=3600
